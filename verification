from sympy import *
a, b = symbols('a b')

expr = 3*(a**2 - a*b + 7) - 2*(3*a*b - a**2 + 1) + 3

expr_simplified = simplify(expr)

value = expr_simplified.subs({
    a: Rational(2, 1),
    b: Rational(1, 3)
})

assert expr_simplified == 5*a**2 - 9*a*b + 22
assert value == 36

print(f"Simplified expression: {expr_simplified}")
